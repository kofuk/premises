{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchDepNames": ["ghcr.io/kofuk/premises"],
      "matchDatasources": ["docker"],
      "enabled": false
    },
    {
      "groupName": "Bun",
      "matchDatasources": ["go"],
      "matchPackageNames": [
        "github.com/uptrace/bun",
        "github.com/uptrace/bun/**"
      ]
    },
    {
      "groupName": "OpenTelemetry-Go",
      "matchDatasources": ["go"],
      "matchDepNames": ["go.opentelemetry.io/**"]
    },
    {
      "groupName": "Redis client for Go",
      "matchDatasources": ["go"],
      "matchSourceUrls": ["https://github.com/redis/go-redis"]
    },
    {
      "groupName": "Go",
      "matchDatasources": ["golang-version"],
      "rangeStrategy": "bump"
    },
    {
      "groupName": "Go",
      "matchDepNames": ["golang"],
      "matchDatasources": ["docker"],
      "rangeStrategy": "bump"
    }
  ]
}
